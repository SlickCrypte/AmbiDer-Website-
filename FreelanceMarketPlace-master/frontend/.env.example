# FreelanceHub Backend API Configuration (Example)
# By default, commenting this out triggers the app to fall back to the live Render cloud API.
VITE_API_BASE_URL=http://localhost:8000

# Google Gemini AI API Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# LinkedIn OAuth Client ID
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here

# GitHub OAuth Client ID
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_preset_here


